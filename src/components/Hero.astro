---
import SearchInput from "./SearchInput";
import ParticleBackground from "./ParticleBackground";

interface Props {
  title: string;
  tagline: string;
  showSearch?: boolean;
  searchPlaceholder?: string;
}

const {
  title,
  tagline,
  showSearch = false,
  searchPlaceholder = "Search by name, category, or feature...",
} = Astro.props;
---

<div class="hero-section nu-u-text--secondary">
  <div class="particles-wrapper">
    <ParticleBackground client:idle />
  </div>

  <div class="hero-content">
    <h1 class="hero-title nu-u-text--primary">
      {title}
    </h1>

    <p class="hero-subtitle">
      {tagline}
    </p>

    {
      showSearch && (
        <div class="search-centered-wrapper">
          <SearchInput client:load placeholder={searchPlaceholder} />
        </div>
      )
    }
  </div>
</div>

<style>
  .hero-section {
    width: 100%;
    position: relative;
    background: linear-gradient(
      to bottom,
      var(--background-high-contrast) 0%,
      transparent 100%
    );
    padding: 3.5rem 2rem 2.5rem;
    margin: 0;
    text-align: center;
    overflow: hidden;
  }

  .particles-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-title {
    color: var(--accent);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0 0 1rem 0;
  }

  .hero-subtitle {
    color: var(--content-secondary);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.6;
    max-width: 540px;
    margin: 0 0 2rem 0;
  }

  /* Center search without constraints, but allow full-width internal scaling */
  .search-centered-wrapper {
    width: 100%;
    max-width: 500px;
    display: flex;
    justify-content: center;
  }
  .hero-section :global(.search-container) {
    display: flex;
    justify-content: center;
    width: 100%;
  }
</style>
