---
interface Props {
  url?: string;
}

const { url = "https://walkscape-index.github.io" } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Walkscape-Index",
  url: url,
  description:
    "The community resource directory for Walkscape tools, databases, and spreadsheets.",
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${url}/?search={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
