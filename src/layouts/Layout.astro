</style>

<script is:inline>
    (function () {
        const updateFavoritesLink = () => {
            try {
                const linkEl = document.getElementById("favoritesLink");
                const countEl = document.getElementById("favoritesCount");
                if (!linkEl || !countEl) return;

                const bookmarksString = localStorage.getItem("rom_bookmarks");
                const count = bookmarksString
                    ? JSON.parse(bookmarksString).length
                    : 0;

                if (count > 0) {
                    linkEl.style.display = "inline-flex";
                    countEl.textContent = count;
                } else {
                    linkEl.style.display = "none";
                    countEl.textContent = "";
                }
            } catch (e) {}
        };

        // Core Initialization (Runs on every page load including initial)
        const init = () => {
            // New Tools Filter Toggle - Idempotent listener
            const newFilterToggle =
                document.querySelector("#new-filter-toggle");
            if (newFilterToggle) {
                if (!newFilterToggle._hasFilterListener) {
                    newFilterToggle.addEventListener("click", () => {
                        const isPressed =
                            newFilterToggle.getAttribute("aria-pressed") ===
                            "true";
                        newFilterToggle.setAttribute(
                            "aria-pressed",
                            !isPressed,
                        );
                        window.dispatchEvent(
                            new CustomEvent("tools:filter-new", {
                                detail: { filterNew: !isPressed },
                            }),
                        );
                    });
                    newFilterToggle._hasFilterListener = true;
                }
            }

            updateFavoritesLink();
        };

        // Theme toggle
        const VALID_THEMES = ['dark--warm', 'dark--cold'];
        const DEFAULT_THEME = 'dark--warm';

        const getSavedTheme = () => {
            try {
                const t = localStorage.getItem('rom_theme');
                return VALID_THEMES.includes(t) ? t : DEFAULT_THEME;
            } catch (e) {
                return DEFAULT_THEME;
            }
        };

        const applyTheme = (theme) => {
            document.documentElement.setAttribute('data-new-ui-theme', theme);
            const btn = document.getElementById('theme-toggle');
            if (btn) {
                const isCold = theme === 'dark--cold';
                btn.setAttribute('aria-pressed', String(isCold));
                btn.setAttribute('aria-label',
                    isCold ? 'Switch to warm theme' : 'Switch to cold theme');
            }
        };

        const initTheme = () => {
            applyTheme(getSavedTheme());

            const themeToggle = document.getElementById('theme-toggle');
            if (themeToggle && !themeToggle._hasThemeListener) {
                themeToggle.addEventListener('click', () => {
                    const current = document.documentElement.getAttribute('data-new-ui-theme');
                    const next = current === 'dark--warm' ? 'dark--cold' : 'dark--warm';
                    try { localStorage.setItem('rom_theme', next); } catch (e) {}
                    applyTheme(next);
                });
                themeToggle._hasThemeListener = true;
            }
        };

        // Global Event Listeners (ensure single attachment)
        if (!window.__rom_initialized) {
            window.addEventListener("bookmarks:changed", updateFavoritesLink);
            window.addEventListener("pageshow", updateFavoritesLink);
            document.addEventListener("astro:before-swap", (e) => {
                const theme = getSavedTheme();
                e.newDocument.documentElement.setAttribute('data-new-ui-theme', theme);
            });
            document.addEventListener("astro:page-load", () => { init(); initTheme(); });
            window.__rom_initialized = true;
        }

        // Initial run for the current page
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", () => { init(); initTheme(); });
        } else {
            init();
            initTheme();
        }
    })();
</script>
