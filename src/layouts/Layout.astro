---
import { ClientRouter } from "astro:transitions";
import WebSiteSchema from "../components/schema/WebSiteSchema.astro";
import Hero from "../components/Hero.astro";
import Nav from "../components/Nav.astro";
import "@new-ui/foundations";

export interface Props {
    site: string;
    title: string;
    tagline: string;
    pageTitle?: string;
    pageDescription?: string;
    canonicalUrl?: string;
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    ogUrl?: string;
    ogType?: string;
    ogSiteName?: string;
    twitterCard?: string;
    twitterTitle?: string;
    twitterDescription?: string;
    twitterImage?: string;
    pageFavicon?: string;
    showSearch?: boolean;
    showLatestFilter?: boolean;
    searchPlaceholder?: string;
}

const {
    site,
    title,
    tagline,
    pageTitle,
    pageDescription,
    canonicalUrl,
    ogTitle,
    ogDescription,
    ogImage,
    ogUrl,
    ogType,
    ogSiteName,
    twitterCard,
    twitterTitle,
    twitterDescription,
    twitterImage,
    pageFavicon,
    showSearch = false,
    showLatestFilter = true,
    searchPlaceholder = "Search by name, category, or feature...",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-new-ui-theme="dark--warm">
    <head>
        <script is:inline>
            (function(){try{var t=localStorage.getItem('rom_theme');if(t==='dark--warm'||t==='dark--cold')document.documentElement.setAttribute('data-new-ui-theme',t);}catch(e){}})();
        </script>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link
            rel="icon"
            type="image/svg+xml"
            href={pageFavicon || "/walkscape-index.svg"}
        />
        <meta name="generator" content={Astro.generator} />
        <title>
            {
                pageTitle
                    ? `${pageTitle} | Walkscape-Index`
                    : `${site} — The community resource directory for Walkscape tools, databases, and spreadsheets..`
            }
        </title>
        <meta name="author" content="@WalkScapeIndex" />
        <meta
            name="description"
            content={pageDescription ||
                "The community resource directory for Walkscape tools, databases, and spreadsheets.."}
        />
        <link rel="sitemap" href="/sitemap-index.xml" />
        {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
        {ogTitle && <meta property="og:title" content={ogTitle} />}
        {ogType && <meta property="og:type" content={ogType} />}
        {
            ogDescription && (
                <meta property="og:description" content={ogDescription} />
            )
        }
        {ogImage && <meta property="og:image" content={ogImage} />}
        {ogUrl && <meta property="og:url" content={ogUrl} />}
        {ogSiteName && <meta property="og:site_name" content={ogSiteName} />}
        {twitterCard && <meta name="twitter:card" content={twitterCard} />}
        {twitterTitle && <meta name="twitter:title" content={twitterTitle} />}
        {
            twitterDescription && (
                <meta name="twitter:description" content={twitterDescription} />
            )
        }
        {twitterImage && <meta name="twitter:image" content={twitterImage} />}

       <script defer src="https://umami-fra9kd688-do-i-need-one-s-projects.vercel.app/mango_banana" data-website-id="7365ec0f-69da-472f-8b7c-a1fe31918735"></script>
        <ClientRouter />
        <WebSiteSchema />
    </head>

    <body>
        <a href="#main-content" class="skip-link">Skip to main content</a>
        <Nav showLatestFilter={showLatestFilter} />
        <script is:inline>
            (function () {
                try {
                    var t = localStorage.getItem("rom_theme");
                    var isCold = t === "dark--cold";
                    var btn = document.getElementById("theme-toggle");
                    if (btn) {
                        btn.setAttribute("aria-pressed", String(isCold));
                        btn.setAttribute(
                            "aria-label",
                            isCold ? "Switch to warm theme" : "Switch to cold theme",
                        );
                    }
                    var raw = localStorage.getItem("rom_bookmarks");
                    var count = 0;
                    if (raw) {
                        try {
                            count = JSON.parse(raw).length || 0;
                        } catch (e) {}
                    }
                    var link = document.getElementById("favoritesLink");
                    var countEl = document.getElementById("favoritesCount");
                    if (link && count > 0) {
                        link.style.display = "inline-flex";
                        if (countEl) countEl.textContent = count;
                    }
                } catch (e) {}
            })();
        </script>

        <Hero
            title={title}
            tagline={tagline}
            showSearch={showSearch}
            searchPlaceholder={searchPlaceholder}
        />
        <slot />

        <div class="footer">
            <p>
                <strong>Walkscape Index</strong> © 2026 <br />
                <a
                    href="https://walkscape-index.github.io"
                    class="nu-u-link--subtle"
                    target="_blank"
                    rel="noopener noreferrer">@walkscape-index</a
                >
                <span class="footer-separator">·</span>
                <a href="/privacy" class="nu-u-link--subtle">Privacy</a>
                <span class="footer-separator">·</span>
                <a href="/terms" class="nu-u-link--subtle">Terms</a>
            </p>
        </div>
    </body>
</html>
<style is:global>
