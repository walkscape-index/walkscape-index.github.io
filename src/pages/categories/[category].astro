---
import Layout from "../../layouts/Layout.astro";

import "@new-ui/foundations";
import Dashboard from "../../components/Dashboard";
import data from "../../data/tools.json";

export function getStaticPaths() {
  // Derive paths from data instead of hardcoding
  return data.tools.map((cat: any) => ({
    params: { category: cat.category }
  }));
}

const { category } = Astro.params;
---

<Layout
  site={`Walkscape-Index - ${category}`}
  title="Walkscape-Index"
  tagline="The community resource directory for Walkscape tools, databases, and spreadsheets."
  showSearch={true}
>
  <main id="main-content">
    <Dashboard client:load category={category} />
  </main>
</Layout>

