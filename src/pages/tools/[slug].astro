  <script type="module">
    function getGiscusTheme() {
      const theme = document.documentElement.getAttribute('data-new-ui-theme');
      return theme === 'dark--cold' ? 'catppuccin_mocha' : 'transparent_dark';
    }

    function loadGiscus() {
      const container = document.querySelector('.giscus');
      if (!container) return;
      if (container.querySelector('iframe')) return;
      container.innerHTML = '';
      const s = document.createElement('script');
      s.src = 'https://giscus.app/client.js?v=' + Date.now();
      s.setAttribute('data-repo', 'walkscape-index/comments');
      s.setAttribute('data-repo-id', 'R_kgDOSiVa9A');
      s.setAttribute('data-category', 'General');
      s.setAttribute('data-category-id', 'DIC_kwDOSiVa9M4C9aZl');
      s.setAttribute('data-mapping', 'pathname');
      s.setAttribute('data-strict', '0');
      s.setAttribute('data-reactions-enabled', '1');
      s.setAttribute('data-emit-metadata', '0');
      s.setAttribute('data-input-position', 'bottom');
      s.setAttribute('data-theme', getGiscusTheme());
      s.setAttribute('data-lang', 'en');
      s.setAttribute('crossorigin', 'anonymous');
      s.async = true;
      container.appendChild(s);
    }

    function closeModal() {
      document.body.removeAttribute("data-modal-open");
      document.body.style.overflow = "";

      const fallback =
        document.getElementById("toolModal")?.dataset.fallback || "/";
      const ref = document.referrer;
      const sameOrigin = ref && new URL(ref, location.href).origin === location.origin;

      if (sameOrigin && window.history.length > 1) window.history.back();
      else window.location.href = fallback;
    }

    function handleInteraction(e) {
      if (
        e.target.closest(".tool-detail-close-btn") ||
        (e.target.closest(".tool-detail-modal-backdrop") &&
          !e.target.closest(".tool-detail-modal"))
      ) {
        e.preventDefault();
        return closeModal();
      }

      const copyBtn = e.target.closest("#copyLinkBtn");
      if (copyBtn) {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const original = copyBtn.innerHTML;
          copyBtn.innerHTML =
            '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
          setTimeout(() => (copyBtn.innerHTML = original), 2000);
        }).catch(() => {});
        return;
      }

      const toggleBtn = e.target.closest("#commentsToggle");
      if (toggleBtn) {
        const wrapper = document.getElementById("giscus-wrapper");
        const statusLabel = toggleBtn.querySelector(".toggle-status-label");
        const arrow = toggleBtn.querySelector(".accordion-arrow");
        if (wrapper) {
          const isExpanded = toggleBtn.getAttribute("aria-expanded") === "true";
          if (isExpanded) {
            toggleBtn.setAttribute("aria-expanded", "false");
            wrapper.style.display = "none";
            if (statusLabel) statusLabel.textContent = "Show";
            if (arrow) arrow.style.transform = "rotate(0deg)";
          } else {
            toggleBtn.setAttribute("aria-expanded", "true");
            wrapper.style.display = "block";
            if (statusLabel) statusLabel.textContent = "Hide";
            if (arrow) arrow.style.transform = "rotate(180deg)";
            loadGiscus();
          }
        }
        return;
      }

      const themeToggle = e.target.closest('#theme-toggle');
      if (themeToggle) {
        requestAnimationFrame(() => {
          const iframe = document.querySelector('iframe.giscus-frame');
          if (iframe) {
            iframe.contentWindow?.postMessage(
              { giscus: { setConfig: { theme: getGiscusTheme() } } },
              'https://giscus.app'
            );
          }
        });
      }
    }

    function handleKeydown(e) {
      if (e.key === "Escape") closeModal();
    }

    function cleanup() {
      document.removeEventListener("click", handleInteraction);
      document.removeEventListener("keydown", handleKeydown);
      document.body.removeAttribute("data-modal-open");
      document.body.style.overflow = "";
    }

    function init() {
      const modal = document.getElementById("toolModal");
      if (!modal) return;

      cleanup();

      const contentWrapper = document.querySelector(".tool-detail-content-wrapper");
      if (contentWrapper) contentWrapper.scrollTop = 0;

      document.body.setAttribute("data-modal-open", "true");
      document.body.style.overflow = "hidden";

      document.addEventListener("click", handleInteraction);
      document.addEventListener("keydown", handleKeydown);

      loadGiscus();
    }

    init();

    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:before-preparation", cleanup);
    window.addEventListener("pagehide", cleanup);
  </script>

